# Variables del API de CgRM. Copia este archivo a server/.env y rellena los valores.
# Los scripts (start, migrate, seed) lo cargan con --env-file-if-exists=.env.

# Cadena de conexión de Postgres (Neon). Obligatoria: sin ella el servidor no arranca.
# Cópiala del panel de Neon (Connection string > Node.js). Los parámetros sslmode y
# channel_binding se ignoran: db.js exige verificación real del certificado.
DATABASE_URL=postgresql://usuario:password@ep-xxxx-xxxx.eu-central-1.aws.neon.tech/cgrm

# Secreto para firmar los JWT de sesión (12h de validez).
# En desarrollo puede omitirse (usa un valor por defecto); en producción es obligatorio.
# Genéralo con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CGRM_JWT_SECRET=

# Puerto del API. Por defecto 4000, que es el que la app espera en desarrollo.
PORT=4000

# Almacenamiento de evidencias (fotos y vídeos) — ver server/src/storage.js.
# Sin estas tres variables el servidor cae solo al driver "local" (server/uploads/),
# válido para desarrollar pero no para producción.
#
# URL del proyecto Supabase (Settings > API > Project URL).
SUPABASE_URL=https://cjmtuarhasnqlyasiwoq.supabase.co

# Service role key del proyecto (Settings > API > service_role secret). NUNCA la clave
# publishable/anon: esta clave salta la RLS y es la única forma de firmar subidas/lecturas
# en el bucket privado. No la subas a git ni la compartas.
SUPABASE_SERVICE_KEY=

# Bucket privado ya creado (migración create_evidencias_bucket): límite 120 MB/objeto,
# mime types restringidos a foto/vídeo. No hace falta tocarlo salvo que cambie el nombre.
SUPABASE_BUCKET=evidencias

# Fuerza el driver explícitamente si hace falta. Por defecto: "supabase" si están
# SUPABASE_URL+SUPABASE_SERVICE_KEY, si no "local".
# STORAGE_DRIVER=supabase
